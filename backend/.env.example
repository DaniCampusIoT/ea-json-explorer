# Copia este archivo como .env en la misma carpeta (backend/.env)
# NO subas el .env al repositorio

# Tu clave de OpenAI (obligatoria para las funciones IA)
OPENAI_API_KEY=sk-...

# Modelo a usar. gpt-4o-mini es más rápido y barato para pruebas
OPENAI_MODEL=gpt-4o-mini

# --- Instrucciones Windows ---
# 1. En el explorador de archivos ve a ea-json-explorer/backend/
# 2. Crea un archivo nuevo llamado exactamente:  .env
#    (en Windows puede que necesites usar el Bloc de notas: Archivo > Guardar como > nombre: .env > todos los archivos)
# 3. Pega dentro:  OPENAI_API_KEY=sk-TU_CLAVE_AQUI
# 4. Guarda y reinicia el backend con:  uvicorn main:app --reload --port 8000
